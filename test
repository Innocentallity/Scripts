game.Players.PlayerAdded:Connect(function(plr)
	plr:LoadCharacter()
	local a2 = Instance.new("Folder")
	a2.Name = "Cooldowns"
	a2.Parent = plr
	local a = Instance.new("StringValue")
	a.Name = "CurrentForm"
	a.Value = "BASE"
	a.Parent = plr
	local HP = Instance.new("NumberValue")
	HP.Name = "HP"
	HP.Value = 1500
	HP.Parent = plr
	local PL = Instance.new("NumberValue")
	PL.Name = "PL"
	PL.Value = 5
	PL.Parent = plr
	local UIOB = Instance.new("BoolValue")
	UIOB.Name = "ObtainedUI"
	UIOB.Parent = plr
	local Data = game:GetService("DataStoreService"):GetDataStore("MainData")
	local data = Data:GetAsync(plr.UserId)
	if data then
		pcall(function()
			HP.Value = data[1]
			PL.Value = data[2]
			UIOB.Value = data[3]
		end)
		repeat
			game:GetService("RunService").Heartbeat:Wait()
		until plr.Character
		plr.Character.Humanoid.MaxHealth = HP.Value
		plr.Character.Humanoid.Health = HP.Value
	end
	plr.CharacterAdded:Connect(function()
		for i,v in pairs(plr.Cooldowns:GetChildren()) do
			v:Destroy()
		end
		plr.CurrentForm.Value = "BASE"
		plr.Character:WaitForChild("Humanoid").MaxHealth = HP.Value
		plr.Character:WaitForChild("Humanoid").Health = HP.Value
	end)
end)

game.Players.PlayerRemoving:Connect(function(plr)
